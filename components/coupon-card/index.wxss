.coupon-card {
  display: flex;
  padding: 24rpx;
  background: #fff5f0;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.coupon-card.useful {
  background: #fff5f0;
}

.coupon-card.useless {
  background: #f5f5f5;
  opacity: 0.6;
}

.coupon-left {
  flex-shrink: 0;
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 2rpx dashed #ddd;
  padding-right: 24rpx;
  margin-right: 24rpx;
}

.coupon-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff5500;
  line-height: 1;
}

.coupon-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.coupon-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.coupon-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #ff5500;
  color: #fff;
  font-size: 20rpx;
  border-radius: 4rpx;
  align-self: flex-start;
}

.coupon-operator {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}
