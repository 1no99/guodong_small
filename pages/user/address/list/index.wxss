page {
  background: #f5f5f5;
  height: 100%;
}

.address-container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: calc(env(safe-area-inset-bottom) + 172rpx);
  height: 100vh;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
}

.address-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

/* 选择圆圈 */
.address-radio {
  flex-shrink: 0;
}

.radio-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.radio-circle.checked {
  border-color: #fa4126;
  background-color: #fa4126;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #fff;
}


.address-item.default::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background-color: #fa4126;
}

.address-content {
  flex: 1;
  position: relative;
}

/* 删除图标 */
.delete-icon {
  position: absolute;
  top: 0;
  right: 0;
  padding: 8rpx;
  z-index: 10;
}


.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 24rpx;
}

.phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 40rpx;
  margin-bottom: 12rpx;
}

.address-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-default {
  background-color: #fa4126;
  color: #fff;
}

.tag-primary {
  background-color: #f0f0f0;
  color: #666;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

/* 底部按钮 */
.bottom-bar {
  border-top: 1rpx solid #e5e5e5;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: #fff;
  padding: 12rpx 32rpx calc(env(safe-area-inset-bottom) + 12rpx) 32rpx;
}

.btn-group {
  width: 100%;
  display: flex;
  gap: 24rpx;
}

.add-btn {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #fa4126 100%);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.confirm-btn {
  flex: 1;
  height: 88rpx;
  background-color: #fa4126;
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}


/* 原有样式保留 */
.address-list .no-address {
  width: 750rpx;
  padding-top: 30vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
}
