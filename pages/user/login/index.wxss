.login-page {
  min-height: 100vh;
  padding: 80rpx 60rpx 40rpx;
  background-color: #ccc;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 返回按钮 */
.back-button {
  position: absolute;
  top: 100rpx;
  left: 0rpx;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  backdrop-filter: blur(10rpx);
}

.back-button:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
  margin-top: 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 46rpx;
  background: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录区域 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 80rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.wechat-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.wechat-icon image {
  width: 100%;
  height: 100%;
}

.login-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 48rpx;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.wechat-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.4);
}

/* 手机号输入框 */
.phone-input-group {
  width: 100%;
  margin-bottom: 40rpx;
}

.phone-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.phone-input:focus {
  border-color: #07c160;
}

/* 昵称确认区域 */
.nickname-confirm {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 头像选择区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  width: 100%;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
  border: 4rpx dashed #ccc;
  margin-bottom: 16rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
}

/* 用户协议 */
.agreement-section {
  margin-top: auto;
  padding: 40rpx 0;
  text-align: center;
}

.agreement-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.agreement-link {
  font-size: 24rpx;
  color: #fff;
  text-decoration: underline;
  margin: 0 4rpx;
}
