<!-- 购物车页面 -->
<view class="cart-page">
  <!-- 购物车有商品 -->
  <block wx:if="{{cartGroupData.goodsList.length > 0}}">
    <!-- 有效商品列表 -->
    <view class="goods-wrap">
      <block wx:for="{{cartGroupData.goodsList}}" wx:key="cart_id">
        <view class="goods-item">
          <view class="goods-item-info">
            <!-- 选择框 -->
            <view class="check-wrap" catchtap="onGoodsSelect" data-goods="{{item}}">
              <t-icon
                size="40rpx"
                color="{{item.isSelected ? '#FA4126' : '#BBBBBB'}}"
                name="{{item.isSelected ? 'check-circle-filled' : 'circle'}}"
              />
            </view>

            <!-- 商品信息 -->
            <view class="goods-sku-info">
              <!-- 商品图片 -->
              <image
                class="goods-thumb"
                src="{{item.typesimg}}"
                mode="aspectFill"
                bindtap="goGoodsDetail"
                data-spuId="{{item.spuId}}"
              />

              <!-- 商品详情 -->
              <view class="goods-detail">
                <view class="goods-title" style="width: 90%;" bindtap="goGoodsDetail" data-spuId="{{item.spuId}}">{{item.title}}</view>
                <!-- 调试信息 -->
            
                <view class="goods-specs" >
                    <text  class="spec-item">{{item.specInfo}}</text>
                </view>

                <!-- 价格和数量 -->
                <view class="goods-footer">
                  <view class="goods-price">
                    <text class="price-symbol">¥</text>
                    <text class="price-value">{{item.price}}</text>
                  </view>

                  <!-- 数量选择器 -->
                  <view class="stepper-wrap">
                    <view class="stepper-btn" catchtap="onStepperChange" data-goods="{{item}}" data-type="minus">
                      <text>-</text>
                    </view>
                    <view class="stepper-input">{{item.quantity}}</view>
                    <view class="stepper-btn" catchtap="onStepperChange" data-goods="{{item}}" data-type="plus">
                      <text>+</text>
                    </view>
                  </view>
                </view>
              </view>

              <!-- 删除按钮 -->
              <view class="delete-btn" catchtap="onGoodsDelete" data-goods="{{item}}">
                <t-icon name="delete" size="40rpx" color="#BBBBBB" />
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
   

    <!-- 底部结算栏 -->
    <view class="cart-bar fixed-bottom">
      <view class="cart-bar-content">
        <!-- 全选 -->
        <view class="select-all" catchtap="onSelectAll">
          <t-icon
            size="40rpx"
            color="{{cartGroupData.isAllSelected ? '#FA4126' : '#BBBBBB'}}"
            name="{{cartGroupData.isAllSelected ? 'check-circle-filled' : 'circle'}}"
          />
          <text class="select-all-text">全选</text>
        </view>

        <!-- 总价信息 -->
        <view class="price-info">
          <view class="price-text">
            <text class="price-label">合计：</text>
            <text class="price-symbol">¥</text>
            <text class="price-value">{{cartGroupData.totalAmount}}</text>
          </view>
          <view class="goods-count">
            已选{{cartGroupData.selectedGoodsCount}}件
          </view>
        </view>

        <!-- 结算按钮 -->
        <view class="settle-btn" catchtap="onToSettle">
          结算({{cartGroupData.selectedGoodsCount}})
        </view>
      </view>
    </view>
  </block>

  <!-- 空购物车 -->
  <view class="empty-cart" wx:elif="{{cartGroupData && !cartGroupData.isNotEmpty}}">
    <image class="empty-img" src="https://tdesign.gtimg.com/miniprogram/template/retail/order/empty-order-list.png" mode="aspectFit" />
    <view class="empty-text">购物车空空如也</view>
    <view class="empty-btn" catchtap="onGotoHome">去逛逛</view>
  </view>
</view>

<t-toast id="t-toast" />
<t-dialog id="t-dialog" />
