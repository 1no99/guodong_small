.order-confirm-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 收货地址 */
.address-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  position: relative;
}

.address-info {
  position: relative;
  padding-right: 40rpx;
}

.address-user {
  margin-bottom: 16rpx;
}

.address-user .name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-right: 24rpx;
}

.address-user .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 40rpx;
}

.no-address {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 40rpx;
}

.no-address-text {
  font-size: 32rpx;
  color: #999;
}

.arrow-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #ccc;
}

/* 商品信息 */
.goods-section {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.section-title {
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-card {
  display: flex;
  padding: 30rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  font-size: 32rpx;
  color: #fa4126;
  font-weight: 500;
}

.goods-quantity {
  font-size: 28rpx;
  color: #999;
}

/* 数量选择 */
.quantity-section {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #333;
}

/* 订单备注 */
.remark-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.remark-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.remark-input {
  width: 100%;
  font-size: 28rpx;
  color: #333;
}

/* 价格信息 */
.price-section {
  background-color: #fff;
  padding: 30rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.price-row.total {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-price {
  font-size: 36rpx;
  color: #fa4126;
  font-weight: 500;
}


/* 底部提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-text {
  font-size: 28rpx;
  color: #333;
}

.submit-total-price {
  font-size: 36rpx;
  color: #fa4126;
  font-weight: 500;
}

.submit-btn {
  width: 280rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #fa4126 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 订单成功弹窗 */
.order-success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 580rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.modal-icon {
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.modal-btns {
  width: 100%;
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
  line-height: 80rpx;
}

.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #333;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #ff6b6b 0%, #fa4126 100%);
  color: #fff;
  border: none;
}
